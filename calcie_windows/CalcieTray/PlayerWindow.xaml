<Window x:Class="CalcieTray.PlayerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="CALCIE Player"
        Width="960"
        Height="720"
        MinWidth="720"
        MinHeight="520"
        Background="#151312"
        Foreground="#F2ECE6"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="14"
                Margin="0,0,0,12"
                CornerRadius="14"
                Background="#1D1917"
                BorderBrush="#3D332E"
                BorderThickness="1">
            <StackPanel>
                <DockPanel LastChildFill="False">
                    <StackPanel DockPanel.Dock="Left">
                        <TextBlock Text="CALCIE Player"
                                   FontSize="28"
                                   FontWeight="Bold" />
                        <TextBlock x:Name="SubtitleText"
                                   Margin="0,6,0,0"
                                   Text="Single CALCIE-owned player surface for the Windows beta."
                                   Foreground="#C9BEB4"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                    <Border DockPanel.Dock="Right"
                            Padding="12,6"
                            CornerRadius="999"
                            Background="#2B2522">
                        <TextBlock x:Name="StateText"
                                   Text="Ready"
                                   FontWeight="SemiBold" />
                    </Border>
                </DockPanel>

                <StackPanel Orientation="Horizontal"
                            Margin="0,12,0,0">
                    <Button Content="Reload"
                            Padding="12,8"
                            Margin="0,0,8,0"
                            Click="Reload_Click" />
                    <Button Content="YouTube"
                            Padding="12,8"
                            Margin="0,0,8,0"
                            Click="YouTube_Click" />
                    <Button Content="YouTube Music"
                            Padding="12,8"
                            Click="YouTubeMusic_Click" />
                </StackPanel>
            </StackPanel>
        </Border>

        <Border Grid.Row="1"
                CornerRadius="18"
                Background="#0E0D0D"
                BorderBrush="#3D332E"
                BorderThickness="1"
                ClipToBounds="True">
            <WebBrowser x:Name="Browser" />
        </Border>
    </Grid>
</Window>
