<Window x:Class="CalcieTray.PlayerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="CALCIE Player"
        Width="960"
        Height="720"
        MinWidth="720"
        MinHeight="520"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#141212" Offset="0" />
                <GradientStop Color="#171414" Offset="0.6" />
                <GradientStop Color="#101010" Offset="1" />
            </LinearGradientBrush>
        </Grid.Background>
        <Grid Margin="18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Style="{StaticResource SectionCardStyle}"
                    Margin="0,0,0,14"
                    Background="#1A1716">
                <StackPanel>
                    <DockPanel LastChildFill="False">
                        <StackPanel DockPanel.Dock="Left">
                            <TextBlock Text="CALCIE Player"
                                       Style="{StaticResource PageTitleStyle}" />
                            <TextBlock x:Name="SubtitleText"
                                       Margin="0,8,0,0"
                                       Text="Single CALCIE-owned player surface for the Windows beta."
                                       Style="{StaticResource BodyTextStyle}" />
                        </StackPanel>
                        <Border DockPanel.Dock="Right"
                                Padding="12,7"
                                CornerRadius="999"
                                Background="#2B2522"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1">
                            <TextBlock x:Name="StateText"
                                       Text="Ready"
                                       FontWeight="SemiBold" />
                        </Border>
                    </DockPanel>

                    <WrapPanel Margin="0,14,0,0">
                        <Button Content="Reload"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Margin="0,0,8,0"
                                Click="Reload_Click" />
                        <Button Content="YouTube"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Margin="0,0,8,0"
                                Click="YouTube_Click" />
                        <Button Content="YouTube Music"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Click="YouTubeMusic_Click" />
                    </WrapPanel>
                </StackPanel>
            </Border>

            <Border Grid.Row="1"
                    CornerRadius="22"
                    Background="#0D0D0D"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    ClipToBounds="True">
                <WebBrowser x:Name="Browser" />
            </Border>
        </Grid>
    </Grid>
</Window>
