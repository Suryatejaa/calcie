<Window x:Class="CalcieTray.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="CALCIE Settings"
        Width="450"
        Height="700"
        MinWidth="450"
        MinHeight="700"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource WindowBackgroundBrush}">
    <Grid Background="{StaticResource WindowBackgroundBrush}">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="16">
                <Border Style="{StaticResource SectionCardStyle}"
                        Margin="0,0,0,10"
                        Background="#8C15171A">
                    <StackPanel>
                        <TextBlock Text="CALCIE Settings"
                                   Style="{StaticResource PageTitleStyle}" />
                        <TextBlock Text="{Binding RuntimeStateLabel}"
                                   Margin="0,6,0,0"
                                   Foreground="{StaticResource WarningBrush}"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="{Binding RuntimeDetail}"
                                   Margin="0,6,0,0"
                                   Style="{StaticResource BodyTextStyle}" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SectionCardStyle}"
                        Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="First-Run Memory Import"
                                   Style="{StaticResource SectionTitleStyle}" />
                        <TextBlock Text="Ask ChatGPT for a memory export, then paste the fenced response here. CALCIE stores it locally on this machine."
                                   Margin="0,5,0,8"
                                   Style="{StaticResource BodyTextStyle}" />
                        <TextBox Text="{Binding ProfileImportPrompt, Mode=OneWay}"
                                 IsReadOnly="True"
                                 TextWrapping="Wrap"
                                 Style="{StaticResource InputTextBoxStyle}"
                                 Height="90"
                                 MaxHeight="90" />
                        <WrapPanel Margin="0,8,0,8">
                            <Button Content="Copy Prompt"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Margin="0,0,6,0"
                                    Command="{Binding CopyProfileImportPromptCommand}" />
                        </WrapPanel>
                        <TextBox Text="{Binding ProfileImportText, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 Style="{StaticResource InputTextBoxStyle}"
                                 Height="120"
                                 MaxHeight="120" />
                        <WrapPanel Margin="0,8,0,0">
                            <Button Content="Import ChatGPT Memory"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Command="{Binding ImportProfileCommand}" />
                        </WrapPanel>
                        <TextBlock Text="{Binding ProfileImportMessage}"
                                   Margin="0,8,0,0"
                                   Style="{StaticResource BodyTextStyle}" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SectionCardStyle}"
                        Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="Vision Settings"
                                   Style="{StaticResource SectionTitleStyle}" />
                        <TextBlock Text="Use this goal when starting the background vision monitor."
                                   Margin="0,5,0,8"
                                   Style="{StaticResource BodyTextStyle}" />
                        <TextBox Text="{Binding VisionGoal, UpdateSourceTrigger=PropertyChanged}"
                                 TextWrapping="Wrap"
                                 Style="{StaticResource InputTextBoxStyle}"
                                 Height="64"
                                 MaxHeight="64" />
                        <WrapPanel Margin="0,8,0,0">
                            <Button Content="Start Vision"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Margin="0,0,6,0"
                                    Command="{Binding StartVisionCommand}" />
                            <Button Content="Stop Vision"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Command="{Binding StopVisionCommand}" />
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SectionCardStyle}"
                        Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="Updates"
                                   Style="{StaticResource SectionTitleStyle}" />
                        <TextBlock Text="{Binding UpdateStatusMessage}"
                                   Margin="0,6,0,8"
                                   Style="{StaticResource BodyTextStyle}" />
                        <WrapPanel>
                            <Button Content="Check Updates"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Margin="0,0,6,0"
                                    Command="{Binding RefreshUpdateCommand}" />
                            <Button Content="Download"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Margin="0,0,6,0"
                                    Command="{Binding DownloadUpdateCommand}" />
                            <Button Content="Release Notes"
                                    Style="{StaticResource GhostButtonStyle}"
                                    Command="{Binding OpenReleaseNotesCommand}" />
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SectionCardStyle}"
                        Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="Runtime Notes"
                                   Style="{StaticResource SectionTitleStyle}" />
                        <ItemsControl ItemsSource="{Binding PermissionWarnings}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}"
                                               Margin="0,4,0,0"
                                               Style="{StaticResource BodyTextStyle}"
                                               TextWrapping="Wrap" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Text="Windows startup and native permission surfaces will be expanded in the next beta slice."
                                   Margin="0,8,0,0"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   FontSize="11.5"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SectionCardStyle}">
                    <StackPanel>
                        <TextBlock Text="Recent Events"
                                   Style="{StaticResource SectionTitleStyle}" />
                        <ListBox Height="140"
                                 MaxHeight="140"
                                 Margin="0,8,0,0"
                                 Style="{StaticResource CalcieListBoxStyle}"
                                 ItemsSource="{Binding Events}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,8"
                                            Padding="9"
                                            CornerRadius="14"
                                            Background="{StaticResource SurfaceAltBrush}"
                                            BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Summary}"
                                                       FontSize="12.5"
                                                       FontWeight="SemiBold"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Margin="0,5,0,0"
                                                       Text="{Binding MetaLine}"
                                                       Foreground="{StaticResource TextMutedBrush}"
                                                       FontSize="11.5"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
