<Window x:Class="CalcieTray.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="CALCIE"
        Width="408"
        Height="566"
        MinWidth="408"
        MaxWidth="408"
        MinHeight="566"
        MaxHeight="566"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="Manual">
    <Border CornerRadius="28"
            Background="#D60A0B0C"
            BorderBrush="#4A444B52"
            BorderThickness="1"
            Padding="8">
        <Grid>
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#C2141518" Offset="0" />
                    <GradientStop Color="#CE101114" Offset="0.58" />
                    <GradientStop Color="#BC0A0B0D" Offset="1" />
                </LinearGradientBrush>
            </Grid.Background>

            <Grid Margin="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0"
                      Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Ask CALCIE"
                                   Style="{StaticResource PageTitleStyle}" />
                        <TextBlock Text="Follow up, review responses, send normal commands, or use the eye button for a one-time vision check."
                                   Margin="0,4,12,0"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   FontSize="13.5"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                HorizontalAlignment="Right">
                        <Border Padding="12,6"
                                CornerRadius="16"
                                Background="{StaticResource SurfaceAltBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1">
                            <TextBlock Text="{Binding RuntimeState}"
                                       FontSize="13.5"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}" />
                        </Border>
                    </StackPanel>
                </Grid>

                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding ResponseHistory}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource SectionCardStyle}"
                                        Margin="0,0,0,10"
                                        Background="#A617181C"
                                        Padding="14">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Speaker}"
                                                   Style="{StaticResource SectionTitleStyle}"
                                                   Margin="0,0,0,10"
                                                   Foreground="{StaticResource TextMutedBrush}" />
                                        <TextBlock Text="{Binding Body}"
                                                   Style="{StaticResource BodyTextStyle}"
                                                   FontSize="14.5"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <Grid Grid.Row="2"
                      Margin="0,12,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            Margin="0,0,10,0"
                            Command="{Binding StartVoiceCommand}"
                            Style="{StaticResource IconButtonStyle}"
                            Content="&#xE720;" />

                    <TextBox x:Name="PendingCommandTextBox"
                             Grid.Column="1"
                             Margin="0,0,10,0"
                             Padding="14,10"
                             Background="#9C23252B"
                             BorderBrush="#5A5F636B"
                             BorderThickness="1.2"
                             Foreground="{StaticResource TextPrimaryBrush}"
                             FontSize="14.5"
                             FontWeight="SemiBold"
                             Text="{Binding PendingCommand, UpdateSourceTrigger=PropertyChanged}"
                             TextWrapping="NoWrap"
                             AcceptsReturn="False"
                             VerticalContentAlignment="Center"
                             VerticalAlignment="Center"
                             PreviewKeyDown="PendingCommandTextBox_OnPreviewKeyDown"
                             ToolTip="Press Enter to send." />

                    <Button Grid.Column="2"
                            Margin="0,0,8,0"
                            Command="{Binding SubmitVisionCommand}"
                            Style="{StaticResource IconButtonStyle}"
                            Content="&#xE8A7;" />

                    <Button Grid.Column="3"
                            Width="42"
                            Height="42"
                            Command="{Binding SubmitCommand}"
                            Style="{StaticResource PrimaryButtonStyle}"
                            FontSize="18"
                            Content="↑" />
                </Grid>

                <Expander Grid.Row="3"
                          ExpandDirection="Down"
                          Foreground="{StaticResource TextPrimaryBrush}">
                    <Expander.Header>
                        <TextBlock Text="Tools &amp; Status"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   FontSize="13.5"
                                   FontWeight="Bold" />
                    </Expander.Header>

                    <Border Margin="0,8,0,0"
                            Style="{StaticResource SectionCardStyle}"
                            Background="#7A111214">
                        <StackPanel>
                            <WrapPanel Margin="0,0,0,8">
                                <Button Content="Talk"
                                        Margin="0,0,8,8"
                                        Command="{Binding StartVoiceCommand}"
                                        Style="{StaticResource SecondaryButtonStyle}" />
                                <Button Content="Stop"
                                        Margin="0,0,8,8"
                                        Command="{Binding StopVoiceCommand}"
                                        Style="{StaticResource SecondaryButtonStyle}" />
                                <Button Content="Settings"
                                        Margin="0,0,8,8"
                                        Command="{Binding OpenSettingsCommand}"
                                        Style="{StaticResource SecondaryButtonStyle}" />
                                <Button Content="Player"
                                        Margin="0,0,8,8"
                                        Command="{Binding OpenPlayerCommand}"
                                        Style="{StaticResource SecondaryButtonStyle}" />
                                <Button Content="Refresh"
                                        Margin="0,0,8,8"
                                        Command="{Binding RefreshCommand}"
                                        Style="{StaticResource SecondaryButtonStyle}" />
                                <Button Content="Restart Runtime"
                                        Margin="0,0,8,8"
                                        Command="{Binding RestartRuntimeCommand}"
                                        Style="{StaticResource SecondaryButtonStyle}" />
                                <Button Content="Start Vision"
                                        Margin="0,0,8,8"
                                        Command="{Binding StartVisionCommand}"
                                        Style="{StaticResource SecondaryButtonStyle}" />
                                <Button Content="Stop Vision"
                                        Margin="0,0,8,8"
                                        Command="{Binding StopVisionCommand}"
                                        Style="{StaticResource SecondaryButtonStyle}" />
                            </WrapPanel>

                            <TextBlock Text="{Binding RuntimeDetail}"
                                       Margin="0,0,0,6"
                                       Style="{StaticResource BodyTextStyle}" />
                            <TextBlock Text="{Binding UpdateStatusMessage}"
                                       Margin="0,0,0,6"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       FontSize="12.5"
                                       TextWrapping="Wrap" />
                            <TextBlock Text="{Binding VisionGoal, StringFormat=Vision Goal: {0}}"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       FontSize="12.5"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </Expander>
            </Grid>
        </Grid>
    </Border>
</Window>
