<Window x:Class="CalcieTray.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="CALCIE"
        Width="420"
        Height="620"
        MinWidth="380"
        MinHeight="520"
        Background="#151312"
        Foreground="#F2ECE6"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="CALCIE"
                       FontSize="28"
                       FontWeight="Bold" />
            <TextBlock Text="{Binding RuntimeStateLabel}"
                       Margin="0,4,0,0"
                       FontSize="14"
                       Foreground="#D1C7BD" />
            <TextBlock Text="{Binding RuntimeDetail}"
                       Margin="0,8,0,0"
                       TextWrapping="Wrap"
                       Foreground="#B7AAA0" />
        </StackPanel>

        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    Margin="0,0,0,12">
            <Button Content="Refresh"
                    Padding="12,8"
                    Margin="0,0,8,0"
                    Command="{Binding RefreshCommand}" />
            <Button Content="Restart Runtime"
                    Padding="12,8"
                    Margin="0,0,8,0"
                    Command="{Binding RestartRuntimeCommand}" />
            <Button Content="Talk"
                    Padding="12,8"
                    Margin="0,0,8,0"
                    Command="{Binding StartVoiceCommand}" />
            <Button Content="Stop"
                    Padding="12,8"
                    Margin="0,0,8,0"
                    Command="{Binding StopVoiceCommand}" />
            <Button Content="Open Player"
                    Padding="12,8"
                    Command="{Binding OpenPlayerCommand}" />
        </StackPanel>

        <Border Grid.Row="2"
                Padding="14"
                Margin="0,0,0,12"
                CornerRadius="14"
                Background="#221D1A"
                BorderBrush="#3D332E"
                BorderThickness="1">
            <StackPanel>
                <TextBlock Text="Ask CALCIE"
                           FontSize="15"
                           FontWeight="SemiBold"
                           Margin="0,0,0,10" />
                <TextBox Text="{Binding PendingCommand, UpdateSourceTrigger=PropertyChanged}"
                         Padding="12"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         MinHeight="72"
                         Background="#312925"
                         BorderBrush="#4C4039"
                         Foreground="#F2ECE6" />
                <StackPanel Orientation="Horizontal"
                            Margin="0,10,0,0">
                    <Button Content="Send"
                            Padding="12,8"
                            Margin="0,0,8,0"
                            Command="{Binding SubmitCommand}" />
                    <Button Content="Vision Once"
                            Padding="12,8"
                            Command="{Binding SubmitVisionCommand}" />
                </StackPanel>
            </StackPanel>
        </Border>

        <Border Grid.Row="3"
                Padding="14"
                Margin="0,0,0,12"
                CornerRadius="14"
                Background="#1D1917"
                BorderBrush="#3D332E"
                BorderThickness="1">
            <StackPanel>
                <TextBlock Text="Updates"
                           FontSize="15"
                           FontWeight="SemiBold"
                           Margin="0,0,0,10" />
                <TextBlock Text="{Binding UpdateStatusMessage}"
                           TextWrapping="Wrap"
                           Foreground="#D9CEC3" />
                <StackPanel Orientation="Horizontal"
                            Margin="0,10,0,0">
                    <Button Content="Check Updates"
                            Padding="12,8"
                            Margin="0,0,8,0"
                            Command="{Binding RefreshUpdateCommand}" />
                    <Button Content="Download"
                            Padding="12,8"
                            Margin="0,0,8,0"
                            Command="{Binding DownloadUpdateCommand}" />
                    <Button Content="Release Notes"
                            Padding="12,8"
                            Command="{Binding OpenReleaseNotesCommand}" />
                </StackPanel>
            </StackPanel>
        </Border>

        <Border Grid.Row="4"
                Padding="14"
                Margin="0,0,0,12"
                CornerRadius="14"
                Background="#1D1917"
                BorderBrush="#3D332E"
                BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock Text="Recent Events"
                           FontSize="15"
                           FontWeight="SemiBold"
                           Margin="0,0,0,10" />
                <ListBox Grid.Row="1"
                         ItemsSource="{Binding Events}"
                         Background="#1D1917"
                         BorderThickness="0"
                         Foreground="#F2ECE6">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,8"
                                    Padding="10"
                                    CornerRadius="10"
                                    Background="#2A2421">
                                <StackPanel>
                                    <TextBlock Text="{Binding Summary}"
                                               FontWeight="SemiBold"
                                               TextWrapping="Wrap" />
                                    <TextBlock Margin="0,4,0,0"
                                               Text="{Binding MetaLine}"
                                               Foreground="#B7AAA0"
                                               FontSize="12"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <TextBlock Grid.Row="5"
                   Text="{Binding LastResponse}"
                   TextWrapping="Wrap"
                   Foreground="#D9CEC3" />
    </Grid>
</Window>
