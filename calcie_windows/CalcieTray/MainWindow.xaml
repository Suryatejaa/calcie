<Window x:Class="CalcieTray.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="CALCIE"
        Width="430"
        Height="640"
        MinWidth="430"
        MaxWidth="430"
        MinHeight="640"
        MaxHeight="640"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen">
    <Border CornerRadius="28"
            Background="#E60B0B0C"
            BorderBrush="#40343A40"
            BorderThickness="1"
            Padding="10">
        <Grid>
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#F00E0E10" Offset="0" />
                    <GradientStop Color="#F0131315" Offset="0.55" />
                    <GradientStop Color="#F00B0C0E" Offset="1" />
                </LinearGradientBrush>
            </Grid.Background>
            <Grid Margin="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Style="{StaticResource SectionCardStyle}"
                        Margin="0,0,0,10"
                        Background="#AA141517">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="CALCIE"
                                       Style="{StaticResource PageTitleStyle}" />
                            <TextBlock Text="Windows tray beta"
                                       Margin="0,4,0,0"
                                       Foreground="{StaticResource WarningBrush}"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="{Binding RuntimeDetail}"
                                       Margin="0,8,0,0"
                                       Style="{StaticResource BodyTextStyle}" />
                        </StackPanel>
                        <Border Grid.Column="1"
                                Margin="10,0,0,0"
                                Padding="10,6"
                                CornerRadius="18"
                                Background="#991E2126"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1">
                            <TextBlock Text="{Binding RuntimeStateLabel}"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}" />
                        </Border>
                    </Grid>
                </Border>

                <Border Grid.Row="1"
                        Style="{StaticResource SectionCardStyle}"
                        Margin="0,0,0,10"
                        Background="#AA141517">
                    <StackPanel>
                        <TextBlock Text="Quick Actions"
                                   Style="{StaticResource SectionTitleStyle}"
                                   Margin="0,0,0,8" />
                        <WrapPanel>
                            <Button Content="Refresh"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Margin="0,0,6,6"
                                    Command="{Binding RefreshCommand}" />
                            <Button Content="Restart Runtime"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Margin="0,0,6,6"
                                    Command="{Binding RestartRuntimeCommand}" />
                            <Button Content="Talk"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Margin="0,0,6,6"
                                    Command="{Binding StartVoiceCommand}" />
                            <Button Content="Stop"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Margin="0,0,6,6"
                                    Command="{Binding StopVoiceCommand}" />
                            <Button Content="Open Player"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Margin="0,0,0,6"
                                    Command="{Binding OpenPlayerCommand}" />
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <Border Grid.Row="2"
                        Style="{StaticResource SectionCardStyle}"
                        Margin="0,0,0,10"
                        Background="#AA151618">
                    <StackPanel>
                        <TextBlock Text="Ask CALCIE"
                                   Style="{StaticResource SectionTitleStyle}" />
                        <TextBlock Text="Send typed commands, or use Vision Once for a one-time screen check."
                                   Style="{StaticResource BodyTextStyle}"
                                   Margin="0,4,0,8" />
                        <TextBox Text="{Binding PendingCommand, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource InputTextBoxStyle}"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 Height="76"
                                 MaxHeight="76" />
                        <WrapPanel Margin="0,8,0,0">
                            <Button Content="Send"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Margin="0,0,6,0"
                                    Command="{Binding SubmitCommand}" />
                            <Button Content="Vision Once"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Command="{Binding SubmitVisionCommand}" />
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <Border Grid.Row="3"
                        Style="{StaticResource SectionCardStyle}"
                        Margin="0,0,0,10"
                        Background="#AA141517">
                    <StackPanel>
                        <DockPanel LastChildFill="False">
                            <TextBlock Text="Updates"
                                       Style="{StaticResource SectionTitleStyle}" />
                            <Border DockPanel.Dock="Right"
                                    Padding="8,4"
                                    CornerRadius="999"
                                    Background="#991E2126">
                                <TextBlock Text="alpha"
                                           FontSize="11.5"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontWeight="SemiBold" />
                            </Border>
                        </DockPanel>
                        <TextBlock Text="{Binding UpdateStatusMessage}"
                                   Style="{StaticResource BodyTextStyle}"
                                   Margin="0,8,0,8" />
                        <WrapPanel>
                            <Button Content="Check Updates"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Margin="0,0,6,0"
                                    Command="{Binding RefreshUpdateCommand}" />
                            <Button Content="Download"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Margin="0,0,6,0"
                                    Command="{Binding DownloadUpdateCommand}" />
                            <Button Content="Release Notes"
                                    Style="{StaticResource GhostButtonStyle}"
                                    Command="{Binding OpenReleaseNotesCommand}" />
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <Border Grid.Row="4"
                        Style="{StaticResource SectionCardStyle}"
                        Margin="0,0,0,10"
                        Background="#AA141517">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Text="Recent Events"
                                   Style="{StaticResource SectionTitleStyle}"
                                   Margin="0,0,0,8" />
                        <ListBox Grid.Row="1"
                                 Height="120"
                                 MaxHeight="120"
                                 Style="{StaticResource CalcieListBoxStyle}"
                                 ItemsSource="{Binding Events}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,8"
                                            Padding="10"
                                            CornerRadius="14"
                                            Background="{StaticResource SurfaceAltBrush}"
                                            BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Summary}"
                                                       FontSize="12.5"
                                                       FontWeight="SemiBold"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Margin="0,5,0,0"
                                                       Text="{Binding MetaLine}"
                                                       Foreground="{StaticResource TextMutedBrush}"
                                                       FontSize="11.5"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>

                <Border Grid.Row="5"
                        Style="{StaticResource SectionCardStyle}"
                        Background="#AA111214">
                    <StackPanel>
                        <TextBlock Text="Last Response"
                                   Style="{StaticResource SectionTitleStyle}"
                                   Margin="0,0,0,6" />
                        <TextBlock Text="{Binding LastResponse}"
                                   Style="{StaticResource BodyTextStyle}"
                                   MaxHeight="74" />
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
